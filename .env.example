# =========================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to GitHub.
# =========================================================

# Your OCI User OCID (Console -> Profile icon -> User Settings)
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fingerprint of the API signing key you add in User Settings -> API Keys
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx

# Path to your downloaded private key file (keep it OUTSIDE git, e.g. next to this script)
OCI_KEY_FILE=./oci_private_key.pem

# If your private key was generated with a passphrase, put it here. Leave blank/remove if not.
OCI_KEY_PASSPHRASE=

# Your OCI Tenancy OCID (Console -> Profile icon -> Tenancy: <name>)
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region of your tenancy / where you want the instance (e.g. ap-mumbai-1)
OCI_REGION=ap-mumbai-1

# OCID of your Resource Manager Stack (Console -> Developer Services -> Resource Manager -> Stacks)
OCI_STACK_ID=ocid1.ormstack.oc1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================================
# OPTIONAL: Polling tuning (defaults are sane, change only if you know why)
# =========================================================
MIN_WAIT=90
MAX_WAIT=240
RATE_LIMIT_BASE=60
RATE_LIMIT_MAX=600
COOLDOWN_EVERY=15
COOLDOWN_MINUTES=20
